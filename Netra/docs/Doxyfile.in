# Doxyfile for Netra project
PROJECT_NAME           = "Netra"
PROJECT_NUMBER         = "0.2.0"
PROJECT_BRIEF          = "Terminal-based Network Packet Analyzer"
PROJECT_LOGO           =

OUTPUT_DIRECTORY       = @DOXYGEN_OUTPUT_DIRECTORY@
CREATE_SUBDIRS         = YES

# Input settings
INPUT                  = @DOXYGEN_INPUT_DIRECTORY@
INPUT_ENCODING         = UTF-8
FILE_PATTERNS          = *.hpp *.cpp
RECURSIVE              = YES

# Output settings
GENERATE_HTML          = YES
HTML_OUTPUT            = html
GENERATE_LATEX         = YES
LATEX_OUTPUT           = latex
GENERATE_MAN           = NO
GENERATE_RTF           = NO

# Options
EXTRACT_ALL            = NO
EXTRACT_PRIVATE        = NO
EXTRACT_STATIC         = YES
EXTRACT_LOCAL_CLASSES  = YES
CASE_SENSE_FILENAMES   = YES
HIDE_UNDOC_MEMBERS     = YES
HIDE_UNDOC_CLASSES     = YES

# Source browsing
SOURCE_BROWSER         = YES
INLINE_SOURCES         = YES
STRIP_CODE_COMMENTS    = NO

# LaTeX settings
LATEX_CMD_NAME         = latex
MAKEINDEX_CMD_NAME     = makeindex
COMPACT_LATEX          = NO
PAPER_TYPE             = a4
PDF_HYPERLINKS         = YES

# Search settings
SEARCHENGINE           = YES
SERVER_BASED_SEARCH    = NO

# Warnings
QUIET                  = NO
WARNINGS               = YES
WARN_IF_UNDOCUMENTED   = YES
WARN_IF_DOC_LACKED     = YES
WARN_NO_PARAMDOC       = YES

# Optimization
OPTIMIZE_OUTPUT_FOR_C  = NO
OPTIMIZE_FOR_JAVA      = NO
OPTIMIZE_OUTPUT_VHDL   = NO

# Miscellaneous
HAVE_DOT               = YES
DOT_IMAGE_FORMAT       = svg
CALL_GRAPH             = YES
CALLER_GRAPH           = YES
GRAPHICAL_HIERARCHY    = YES
DIRECTORY_GRAPH        = YES

# Markdown support
MARKDOWN_SUPPORT       = YES
USE_MDFILE_AS_MAINPAGE = @CMAKE_CURRENT_SOURCE_DIR@/../README.md
